{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/default/jimokomi",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "console": "integratedTerminal",
      "noDebug": true,
      "preLaunchTask": "build: default",
      "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb"
      },
      "osx": {
        "MIMode": "lldb"
      },
      "windows": {
        "type": "cppvsdbg",
        "program": "${workspaceFolder}\\build\\default\\jimokomi.exe"
      }
    },
    {
      "name": "Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/jimokomi",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "console": "integratedTerminal",
      "preLaunchTask": "build: debug",
      "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb"
      },
      "osx": {
        "MIMode": "lldb"
      },
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "windows": {
        "type": "cppvsdbg",
        "program": "${workspaceFolder}\\build\\debug\\jimokomi.exe"
      }
    },
    {
      "name": "Profile",
      "type": "cppdbg",
      "request": "launch",
