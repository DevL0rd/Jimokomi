      "stopAtEntry": false,
      "externalConsole": false,
      "console": "integratedTerminal",
      "preLaunchTask": "prepare: profile capture",
      "postDebugTask": "finalize: profile capture",
      "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb"
      },
      "osx": {
        "MIMode": "lldb"
      },
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "windows": {
        "type": "cppvsdbg",
        "program": "${workspaceFolder}\\build\\profile\\jimokomi.exe"
      }
    },
    {
